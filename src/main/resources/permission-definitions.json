{
  "apiGroups": {
    "userManagement": {
      "description": "User Management APIs",
      "permissions": [
        {
          "name": "SUPER_ADMIN_ACCESS",
          "resource": "*",
          "operation": "*",
          "api": {
            "endpoint": "*",
            "method": "*"
          },
          "description": "Unrestricted access for super administrators",
          "config": {
            "branchAccess": {
              "type": "ALL_BRANCHES"
            },
            "amountLimit": {
              "enabled": false
            },
            "conditions": [
              "#user.roles.?[name=='SUPER_ADMIN'].size() > 0"
            ]
          },
          "active": true
        },
        {
          "name": "USER_CREATE",
          "resource": "USER",
          "operation": "CREATE",
          "description": "Permission to create new users",
          "api": {
            "endpoint": "/api/users",
            "method": "POST"
          },
          "config": {
            "branchAccess": {
              "type": "SPECIFIC_BRANCHES",
              "branchFieldPath": "branch.id",
              "includeSubBranches": true,
              "allowedBranches": ["HO", "RO"]
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            },
            "validationRules": [
              {
                "name": "validEmail",
                "condition": "#resource.email != null && #resource.email.matches('^[A-Za-z0-9+_.-]+@(.+)$')",
                "errorMessage": "Invalid email format",
                "priority": 1
              },
              {
                "name": "validRole",
                "condition": "#resource.roles != null && !#resource.roles.isEmpty()",
                "errorMessage": "User must have at least one role",
                "priority": 2
              }
            ]
          }
        },
        {
          "name": "USER_VIEW",
          "resource": "USER",
          "operation": "READ",
          "description": "View user details",
          "api": {
            "endpoint": "/api/users/{id}",
            "method": "GET"
          },
          "accessControl": {
            "requiredRole": "USER_ADMIN",
            "branchAccess": "OWN_BRANCH",
            "timeWindow": "24x7"
          }
        },
        {
          "name": "USER_UPDATE",
          "resource": "USER",
          "operation": "UPDATE",
          "description": "Permission to update user details",
          "api": {
            "endpoint": "/api/users/{id}",
            "method": "PUT"
          },
          "config": {
            "branchAccess": {
              "type": "OWN_BRANCH",
              "branchFieldPath": "branch.id",
              "includeSubBranches": false
            },
            "resourceAccess": {
              "accessType": "CONDITIONAL",
              "accessConditions": [
                "#user.roles.?[name=='USER_ADMIN'].size() > 0 or #resource.id != 'admin'",
                "#user.branch.id == #resource.branch.id or #user.roles.?[name=='SUPER_ADMIN'].size() > 0"
              ]
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            }
          }
        },
        {
          "name": "USER_DELETE",
          "resource": "USER",
          "operation": "DELETE",
          "description": "Delete user",
          "api": {
            "endpoint": "/api/users/{id}",
            "method": "DELETE"
          },
          "accessControl": {
            "requiredRole": "USER_ADMIN",
            "branchAccess": "OWN_BRANCH",
            "timeWindow": "09:00-17:00"
          }
        }
      ]
    },
    "roleManagement": {
      "description": "Role Management APIs",
      "permissions": [
        {
          "name": "ROLE_CREATE",
          "resource": "ROLE",
          "operation": "CREATE",
          "description": "Create new role",
          "api": {
            "endpoint": "/api/roles",
            "method": "POST"
          },
          "accessControl": {
            "requiredRole": "SUPER_ADMIN",
            "branchAccess": "ALL_BRANCHES",
            "timeWindow": "24x7"
          }
        },
        {
          "name": "ROLE_VIEW",
          "resource": "ROLE",
          "operation": "READ",
          "description": "View role details",
          "api": {
            "endpoint": "/api/roles/{id}",
            "method": "GET"
          },
          "accessControl": {
            "requiredRole": "USER_ADMIN",
            "branchAccess": "ALL_BRANCHES",
            "timeWindow": "24x7"
          }
        },
        {
          "name": "ROLE_UPDATE",
          "resource": "ROLE",
          "operation": "UPDATE",
          "description": "Update role details",
          "api": {
            "endpoint": "/api/roles/{id}",
            "method": "PUT"
          },
          "accessControl": {
            "requiredRole": "SUPER_ADMIN",
            "branchAccess": "ALL_BRANCHES",
            "timeWindow": "09:00-17:00"
          }
        },
        {
          "name": "ROLE_DELETE",
          "resource": "ROLE",
          "operation": "DELETE",
          "description": "Delete role",
          "api": {
            "endpoint": "/api/roles/{id}",
            "method": "DELETE"
          },
          "accessControl": {
            "requiredRole": "SUPER_ADMIN",
            "branchAccess": "ALL_BRANCHES",
            "timeWindow": "09:00-17:00"
          }
        }
      ]
    },
    "loanManagement": {
      "description": "Loan Management APIs",
      "permissions": [
        {
          "name": "LOAN_CREATE",
          "resource": "LOAN",
          "operation": "CREATE",
          "description": "Permission to create new loan applications",
          "api": {
            "endpoint": "/api/loans",
            "method": "POST"
          },
          "config": {
            "branchAccess": {
              "type": "OWN_BRANCH",
              "branchFieldPath": "branch.id",
              "includeSubBranches": false
            },
            "amountLimit": {
              "enabled": true,
              "limitType": "ROLE_BASED",
              "defaultLimit": 1000000.0,
              "amountFieldPath": "amount",
              "roleLimits": {
                "LOAN_OFFICER": 1000000.0,
                "SENIOR_OFFICER": 2000000.0,
                "MANAGER": 5000000.0
              }
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            },
            "validationRules": [
              {
                "name": "customerCreditScore",
                "condition": "#resource.customer.creditScore >= 600",
                "errorMessage": "Customer credit score must be at least 600",
                "priority": 1
              }
            ]
          }
        },
        {
          "name": "LOAN_VIEW",
          "resource": "LOAN",
          "operation": "READ",
          "description": "View loan details",
          "api": {
            "endpoint": "/api/loans/{id}",
            "method": "GET"
          },
          "accessControl": {
            "requiredRole": "LOAN_OFFICER",
            "branchAccess": "OWN_BRANCH",
            "timeWindow": "24x7"
          }
        },
        {
          "name": "LOAN_UPDATE",
          "resource": "LOAN",
          "operation": "UPDATE",
          "description": "Update loan details",
          "api": {
            "endpoint": "/api/loans/{id}",
            "method": "PUT"
          },
          "accessControl": {
            "requiredRole": "LOAN_OFFICER",
            "branchAccess": "OWN_BRANCH",
            "timeWindow": "09:00-17:00",
            "validationRules": [
              "loan.status != 'APPROVED'",
              "loan.status != 'REJECTED'"
            ]
          }
        },
        {
          "name": "LOAN_APPROVE",
          "resource": "LOAN",
          "operation": "APPROVE",
          "description": "Permission to approve loans with various conditions",
          "api": {
            "endpoint": "/api/loans/{id}/approve",
            "method": "POST"
          },
          "config": {
            "branchAccess": {
              "type": "OWN_BRANCH",
              "branchFieldPath": "branch.id",
              "includeSubBranches": false,
              "allowedBranches": null
            },
            "amountLimit": {
              "enabled": true,
              "limitType": "ROLE_BASED",
              "defaultLimit": 100000.0,
              "amountFieldPath": "amount",
              "roleLimits": {
                "LOAN_OFFICER": 100000.0,
                "SENIOR_OFFICER": 500000.0,
                "MANAGER": 1000000.0,
                "SENIOR_MANAGER": 5000000.0
              }
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            },
            "resourceAccess": {
              "accessType": "CONDITIONAL",
              "accessConditions": [
                "#resource.status == 'PENDING'",
                "#resource.amount > 0",
                "#resource.applicant != null"
              ]
            },
            "conditions": [
              "#user.branch.id == #resource.branch.id",
              "#resource.riskScore <= 70 or #user.roles.?[name=='SENIOR_MANAGER'].size() > 0"
            ],
            "validationRules": [
              {
                "name": "positiveAmount",
                "condition": "#resource.amount > 0",
                "errorMessage": "Loan amount must be positive",
                "priority": 1
              },
              {
                "name": "validStatus",
                "condition": "#resource.status == 'PENDING'",
                "errorMessage": "Only pending loans can be approved",
                "priority": 2
              },
              {
                "name": "riskAssessment",
                "condition": "#resource.riskScore <= 80 or #context.override == true",
                "errorMessage": "High risk loans require override approval",
                "priority": 3
              }
            ]
          }
        },
        {
          "name": "LOAN_REJECT",
          "resource": "LOAN",
          "operation": "REJECT",
          "description": "Reject loan application",
          "api": {
            "endpoint": "/api/loans/{id}/reject",
            "method": "POST"
          },
          "accessControl": {
            "requiredRole": "LOAN_MANAGER",
            "branchAccess": "OWN_BRANCH",
            "timeWindow": "09:00-17:00",
            "validationRules": [
              "loan.status == 'PENDING'"
            ]
          }
        }
      ]
    },
    "branchManagement": {
      "description": "Branch Management APIs",
      "permissions": [
        {
          "name": "BRANCH_CREATE",
          "resource": "BRANCH",
          "operation": "CREATE",
          "description": "Permission to create new branches",
          "api": {
            "endpoint": "/api/branches",
            "method": "POST"
          },
          "config": {
            "branchAccess": {
              "type": "ALL_BRANCHES",
              "includeSubBranches": true
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            },
            "validationRules": [
              {
                "name": "uniqueBranchCode",
                "condition": "@branchRepository.findByCode(#resource.code) == null",
                "errorMessage": "Branch code must be unique",
                "priority": 1
              },
              {
                "name": "validParentBranch",
                "condition": "#resource.parentBranchId == null or @branchRepository.findById(#resource.parentBranchId).isPresent()",
                "errorMessage": "Parent branch must exist",
                "priority": 2
              }
            ]
          }
        },
        {
          "name": "BRANCH_UPDATE",
          "resource": "BRANCH",
          "operation": "UPDATE",
          "description": "Permission to update branch details",
          "api": {
            "endpoint": "/api/branches/{id}",
            "method": "PUT"
          },
          "config": {
            "branchAccess": {
              "type": "BRANCH_HIERARCHY",
              "branchFieldPath": "id",
              "includeSubBranches": true
            },
            "resourceAccess": {
              "accessType": "CONDITIONAL",
              "accessConditions": [
                "#user.roles.?[name=='BRANCH_ADMIN'].size() > 0",
                "!#resource.isHeadOffice or #user.roles.?[name=='SUPER_ADMIN'].size() > 0"
              ]
            },
            "timeAccess": {
              "enabled": true,
              "allowedDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
              "allowedTimeWindows": [
                {
                  "startTime": "09:00",
                  "endTime": "17:00"
                }
              ],
              "timezone": "Asia/Kathmandu"
            }
          }
        }
      ]
    },
    "technicalOperations": {
      "description": "Permissions for technical and system operations",
      "permissions": [
        {
          "name": "SYSTEM_MONITORING",
          "resource": "SYSTEM",
          "operation": "MONITOR",
          "description": "Permission to monitor system health and performance.",
          "api": { "endpoint": "/api/system/monitoring", "method": "GET" },
          "config": {
            "branchAccess": { "type": "ALL_BRANCHES" },
            "timeAccess": { "enabled": false }
          },
          "active": true
        },
        {
          "name": "USER_ACCOUNT_ASSIST",
          "resource": "USER",
          "operation": "ASSIST",
          "description": "Permission to assist with user account issues (e.g., password resets, troubleshooting).",
          "api": { "endpoint": "/api/users/{id}/assist", "method": "POST" },
          "config": {
            "branchAccess": { "type": "ALL_BRANCHES" },
            "timeAccess": { "enabled": false }
          },
          "active": true
        },
        {
          "name": "DATABASE_MAINTENANCE",
          "resource": "DATABASE",
          "operation": "MAINTAIN",
          "description": "Permission to perform database maintenance tasks.",
          "api": { "endpoint": "/api/system/db/maintenance", "method": "POST" },
          "config": {
            "branchAccess": { "type": "ALL_BRANCHES" },
            "timeAccess": { 
              "enabled": true,
              "allowedDays": ["SATURDAY"],
              "allowedTimeWindows": [{"startTime": "00:00", "endTime": "23:59"}],
              "timezone": "Asia/Kathmandu"
            }
          },
          "active": true
        },
        {
          "name": "SYSTEM_CONFIG_UPDATE",
          "resource": "SYSTEM_CONFIG",
          "operation": "UPDATE",
          "description": "Permission to update system configurations.",
          "api": { "endpoint": "/api/system/config", "method": "PUT" },
          "config": {
            "branchAccess": { "type": "ALL_BRANCHES" },
            "timeAccess": {
               "enabled": true,
               "allowedDays": ["SATURDAY"],
               "allowedTimeWindows": [{"startTime": "00:00", "endTime": "23:59"}],
              "timezone": "Asia/Kathmandu"
            }
          },
          "active": true
        }
      ]
    }
  }
} 