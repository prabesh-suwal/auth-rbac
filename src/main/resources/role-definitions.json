{
  "roles": [
    {
      "name": "RELATIONSHIP_MANAGER",
      "description": "Manages client relationships and initiates loan proposals",
      "parentRoleName": "BRANCH_MANAGER",
      "permissions": [
        "LOAN_VIEW",
        "LOAN_CREATE",
        "LOAN_UPDATE",
        "CUSTOMER_VIEW",
        "CUSTOMER_CREATE",
        "CUSTOMER_UPDATE",
        "REPORT_BASIC_VIEW"
      ],
      "configuration": {
        "defaultAmountLimits": {
          "LOAN_PROPOSE": 5000000.0
        },
        "workingHours": {
          "enabled": true,
          "startTime": "08:00",
          "endTime": "18:00",
          "workingDays": ["SUNDAY", "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"]
        },
        "branchRestrictions": {
          "type": "OWN_BRANCH_ONLY",
          "allowCrossBranchView": false
        },
        "approvalChain": {
          "requiresBranchManagerApproval": {
            "enabled": true,
            "amountThreshold": 2000000.0
          },
          "requiresCreditCommitteeApproval": {
            "enabled": true,
            "amountThreshold": 5000000.0
          }
        }
      },
      "active": true
    },
    {
      "name": "LOAN_OFFICER",
      "description": "Processes and evaluates loan applications",
      "parentRoleName": "RELATIONSHIP_MANAGER",
      "permissions": [
        "LOAN_VIEW",
        "LOAN_CREATE",
        "LOAN_UPDATE",
        "LOAN_APPROVE",
        "CUSTOMER_VIEW",
        "CUSTOMER_CREATE",
        "REPORT_BASIC_VIEW"
      ],
      "configuration": {
        "defaultAmountLimits": {
          "LOAN_APPROVE": 1000000.0,
          "LOAN_DISBURSE": 1000000.0
        },
        "workingHours": {
          "enabled": true,
          "startTime": "09:00",
          "endTime": "17:00",
          "workingDays": ["SUNDAY", "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"]
        },
        "branchRestrictions": {
          "type": "OWN_BRANCH_ONLY",
          "allowCrossBranchView": false
        },
        "approvalChain": {
          "requiresBranchManagerApproval": {
            "enabled": true,
            "amountThreshold": 500000.0
          }
        }
      },
      "active": true
    },
    {
      "name": "BRANCH_MANAGER",
      "description": "Manages branch operations and approves loans within limits",
      "parentRoleName": "CREDIT_COMMITTEE_MEMBER",
      "permissions": [
        "LOAN_VIEW",
        "LOAN_CREATE",
        "LOAN_UPDATE",
        "LOAN_APPROVE",
        "LOAN_REJECT",
        "CUSTOMER_VIEW",
        "CUSTOMER_CREATE",
        "CUSTOMER_UPDATE",
        "REPORT_ADVANCED_VIEW",
        "BRANCH_REPORT_VIEW",
        "USER_VIEW",
        "USER_UPDATE"
      ],
      "configuration": {
        "defaultAmountLimits": {
          "LOAN_APPROVE": 10000000.0,
          "LOAN_DISBURSE": 10000000.0
        },
        "workingHours": {
          "enabled": true,
          "startTime": "09:00",
          "endTime": "17:00",
          "workingDays": ["SUNDAY", "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"]
        },
        "branchRestrictions": {
          "type": "OWN_BRANCH_AND_SUBORDINATES",
          "allowCrossBranchView": true
        },
        "approvalChain": {
          "requiresCreditCommitteeApproval": {
            "enabled": true,
            "amountThreshold": 5000000.0
          }
        }
      },
      "active": true
    },
    {
      "name": "CREDIT_COMMITTEE_MEMBER",
